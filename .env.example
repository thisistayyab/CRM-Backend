# Server
PORT=8000
NODE_ENV=production

# Database
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/taylance-crm

# JWT
ACCESS_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRY=10d

# CORS (comma-separated origins — include your CRM subdomain)
CORS_ORIGIN=https://crm.taylancetech.com,http://localhost:5173

# Frontend URL (verification / password reset links)
FRONTEND_URL=https://crm.taylancetech.com

# Company branding (emails)
SUPPORT_EMAIL=hello@taylancetech.com

# Email (SMTP)
# PRODUCTION: use hello@taylancetech.com via Google Workspace / Resend / SendGrid — NOT a personal @gmail.com
# Required DNS on taylancetech.com: SPF + DKIM + DMARC (or emails land in spam)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# With Gmail SMTP, From must match SMTP_USER — Reply-To uses SUPPORT_EMAIL below
SMTP_FROM=hello@taylancetech.com
# Port 465 = SSL (secure:true) | Port 587 = STARTTLS (secure:false)

# Rate limiting (requests per window)
RATE_LIMIT_GENERAL=400
RATE_LIMIT_AUTH=20
RATE_LIMIT_EMAIL=5

# Redis (verification codes)
REDIS_URL=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
